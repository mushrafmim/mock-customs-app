# NSW Backend URL used server-side (API routes)
NSW_BACKEND_URL=http://localhost:8080

# NSW Backend URL exposed to the browser (client-side polling)
NEXT_PUBLIC_NSW_BACKEND_URL=http://localhost:8080

# Absolute path for the SQLite database file
# Mount a Docker volume here so data persists across container restarts
DB_PATH=/app/data/customs.db

# Port the server listens on (default: 3001)
PORT=3001
